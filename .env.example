# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/smart_accounting

# Anthropic (Claude AI) Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key

# Zoho Books API Credentials
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=http://localhost:8000/api/v1/companies/connect-zoho/callback

# Zoho Regional Endpoints (e.g., .com, .eu, .in, etc.)
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_BOOKS_URL=https://www.zohoapis.com/books

# Security configuration
SESSION_SECRET_KEY=some-highly-secure-random-token-string
